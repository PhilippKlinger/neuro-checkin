{
  "expo": {
    "name": "Neuro Check-in",
    "slug": "neuro-checkin",
    "scheme": "neuro-checkin",
    "version": "1.11.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EFE8"
      },
      "versionCode": 22,
      "allowBackup": false,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.philippklinger.neurocheckin",
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Lexend_400Regular.ttf",
            "./assets/fonts/Lexend_500Medium.ttf",
            "./assets/fonts/Lexend_600SemiBold.ttf",
            "./assets/fonts/Lexend_700Bold.ttf",
            "./assets/fonts/AtkinsonHyperlegible_400Regular.ttf",
            "./assets/fonts/AtkinsonHyperlegible_700Bold.ttf",
            "./assets/fonts/Nunito_400Regular.ttf",
            "./assets/fonts/Nunito_500Medium.ttf",
            "./assets/fonts/Nunito_600SemiBold.ttf",
            "./assets/fonts/Nunito_700Bold.ttf"
          ]
        }
      ],
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "26b7c0f2-be40-4619-aadc-124788cc4d67"
      }
    }
  }
}
