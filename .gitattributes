# Normalize line endings to LF on commit, checkout as-is on Windows
* text=auto eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.apk binary
*.aab binary
*.keystore binary
