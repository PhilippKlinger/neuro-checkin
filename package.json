{
  "name": "neuro-checkin",
  "version": "1.11.2",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "npx expo lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "hygiene": "node scripts/check-repo-hygiene.mjs",
    "seed": "node scripts/seed-checkins.js",
    "seed:active": "node scripts/seed-patterns.js active",
    "seed:varied": "node scripts/seed-patterns.js varied",
    "seed:steady": "node scripts/seed-patterns.js steady",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prebuild:clean": "expo prebuild --clean"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/datetimepicker": "8.4.4",
    "@sentry/react-native": "~8.13.0",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.24",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "expo-dev-client": "~6.0.21",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "prettier": "^3.9.3",
    "secretlint": "^13.0.2",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native"
      ]
    }
  },
  "overrides": {
    "shell-quote": "1.8.4",
    "form-data": "4.0.6",
    "ws@6": "6.2.4",
    "ws@7": "7.5.11",
    "ws@8": "8.21.0",
    "undici": "6.27.0"
  }
}
